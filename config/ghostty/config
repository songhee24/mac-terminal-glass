# Ghostty — glassmorphism setup (Catppuccin Mocha)
# Mirrors the Windows Terminal "glass" look: frosted acrylic + JetBrainsMono Nerd Font

# --- Theme / colors ---
theme = Catppuccin Mocha

# --- Font ---
font-family = JetBrainsMono Nerd Font Mono
font-size = 14
font-thicken = true

# --- Glass (transparency + blur) ---
background-opacity = 0.82
background-blur-radius = 20

# --- Cursor ---
cursor-style = bar
cursor-style-blink = true

# --- Window / spacing ---
window-padding-x = 14
window-padding-y = 12
window-padding-balance = true
macos-titlebar-style = transparent
macos-non-native-fullscreen = visible-menu
mouse-hide-while-typing = true

# --- Behavior ---
copy-on-select = clipboard
confirm-close-surface = false
window-save-state = always

# --- macOS-style text editing (match other Mac apps) ---
# Word navigation: Option + ←/→
keybind = alt+left=esc:b
keybind = alt+right=esc:f
# Line navigation: Cmd + ←/→
keybind = cmd+left=text:\x01
keybind = cmd+right=text:\x05
# Delete word (Option+Delete) / delete line (Cmd+Delete)
keybind = alt+backspace=text:\x1b\x7f
keybind = cmd+backspace=text:\x15
# Undo (Cmd+Z)
keybind = cmd+z=text:\x1f
